# Copy this file to .env and keep the .env file private.
# Environment variables for backend contact handling and email replies
EMAIL_USER=contact2saranrk@gmail.com
EMAIL_PASS=your-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_FROM_NAME=Your Name
EMAIL_REPLY_SUBJECT=Thank you for connecting
CONTACT_STORE_PATH=contacts.csv
# When deployed, backend route /api/contact will store contact submissions in the configured CSV file and send the reply email.